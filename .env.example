# SECURITY: placeholders only. Never commit real credentials or private origins here.
NODE_ENV=development
PORT=3000
# Optional comma-separated cross-origin clients. Same-origin browser connections work without this.
ALLOWED_ORIGINS=https://study-desk-library.fly.dev
# Enable only after creating a Google OAuth Web client. The client ID is public;
# the session secret must be generated randomly and stored with `fly secrets set`.
AUTH_REQUIRED=false
GOOGLE_CLIENT_ID=000000000000-example.apps.googleusercontent.com
SESSION_SECRET=replace-with-at-least-32-random-characters
# Only this verified Google account can create, invite to, and delete rooms.
ADMIN_EMAIL=mhayankhan100@gmail.com

# Supabase Free: copy the Session pooler connection string from Project > Connect.
# Keep this server-only. Do not add Supabase browser keys to this application.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PROJECT_PASSWORD@POOLER_HOST:5432/postgres?sslmode=require
DATABASE_REQUIRED=false
